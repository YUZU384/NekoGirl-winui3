# ============================================
# Git 属性配置
# 用于控制文本文件的行尾符和规范化
# ============================================

## 自动检测文本文件并执行 LF 规范化
* text=auto

## ============================================
## 源代码文件 (强制使用 LF)
## ============================================
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.manifest text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.editorconfig text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.bat text eol=lf
*.cmd text eol=lf

## ============================================
## 二进制文件 (不进行任何转换)
## ============================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.webp binary
*.svg binary
*.pdf binary
*.zip binary
*.tar.* binary
*.gz binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.pdb binary
*.obj binary
*.lib binary
*.nupkg binary
*.snk binary
*.pfx binary
*.pri binary
*.xbf binary
*.winmd binary
*.appx binary
*.msix binary
*.msixbundle binary
*.appxbundle binary

## ============================================
## 特殊处理
## ============================================
.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf
