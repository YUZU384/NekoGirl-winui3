<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NekoGirl_winui3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NekoGirl_winui3"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- ============================================ -->
    <!-- 窗口背景效果配置 (WinUI 3 现代化材质) -->
    <!-- ============================================ -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- ============================================ -->
    <!-- 主布局网格 -->
    <!-- ============================================ -->
    <Grid Background="{StaticResource NekoBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏区域 -->
        <Grid x:Name="TitleBarGrid"
              Grid.Row="0" 
              Background="{StaticResource NekoPinkBrush}"
              Height="48"
              Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="10"
                        VerticalAlignment="Center">
                <Image Source="Assets/Neko_256x256.targetsize-256.png" 
                       Width="28" 
                       Height="28"/>
                <TextBlock Text="NekoGirl-猫娘下载器，随机获取猫娘"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧: 图片显示区 -->
            <Border Grid.Column="0"
                    x:Name="ImageDisplayBorder"
                    Background="White"
                    CornerRadius="16"
                    Padding="16"
                    Margin="0,0,20,0"
                    Shadow="{StaticResource CardShadow}"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform X="-100" Y="0"/>
                </Border.RenderTransform>
                <Grid>
                    <!-- 主图片显示控件 -->
                    <Image x:Name="MainImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           RenderTransformOrigin="0.5,0.5"
                           Opacity="0"
                           UseLayoutRounding="True">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                        </Image.RenderTransform>
                    </Image>
                    
                    <!-- 加载进度环 -->
                    <ProgressRing x:Name="LoadingRing"
                                  Width="60"
                                  Height="60"
                                  Foreground="{StaticResource NekoPinkBrush}"
                                  Visibility="Collapsed"
                                  IsActive="True"/>
                    
                    <!-- 占位提示文字 -->
                    <TextBlock x:Name="PlaceholderText"
                               Text="点击「下一只」开始浏览喵~&#x0A;或使用键盘 ← → 方向键"
                               FontSize="16"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="24"/>
                </Grid>
            </Border>

            <!-- 右侧: 控制面板 -->
            <StackPanel Grid.Column="1" Spacing="16">
                
                <!-- 卡片1: 画师信息 -->
                <Border x:Name="ArtistInfoCard"
                        Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Shadow="{StaticResource CardShadow}"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform X="100" Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel Spacing="12">
                        <TextBlock Text="画师信息"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource NekoPinkDarkBrush}"/>
                        
                        <TextBlock x:Name="ArtistText"
                                   Text="暂无信息"
                                   FontSize="14"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"/>
                        
                        <HyperlinkButton x:Name="ArtistLink"
                                         Content="访问画师主页"
                                         NavigateUri=""
                                         Visibility="Collapsed"
                                         Foreground="{StaticResource NekoPinkBrush}"
                                         FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- 卡片2: 浏览控制 -->
                <Border x:Name="BrowseControlCard"
                        Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Shadow="{StaticResource CardShadow}"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform X="100" Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel Spacing="12">
                        <TextBlock Text="浏览控制"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource NekoPinkDarkBrush}"
                                   Margin="0,0,0,8"/>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="PrevButton"
                                    Grid.Column="0"
                                    Click="PrevButton_Click"
                                    IsEnabled="False"
                                    Style="{StaticResource NekoButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="上一张 (← 方向键)">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                                    <TextBlock Text="上一只"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="NextButton"
                                    Grid.Column="1"
                                    Click="NextButton_Click"
                                    Style="{StaticResource NekoButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="下一张 (→ 方向键或空格)">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="下一只"/>
                                    <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="快捷键: ← → 方向键 或 空格键"
                                   FontSize="11"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <!-- 卡片3: 保存管理 -->
                <Border x:Name="SaveManageCard"
                        Background="White"
                        CornerRadius="16"
                        Padding="20"
                        Shadow="{StaticResource CardShadow}"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform X="100" Y="0"/>
                    </Border.RenderTransform>
                    <StackPanel Spacing="12">
                        <TextBlock Text="保存管理"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource NekoPinkDarkBrush}"
                                   Margin="0,0,0,8"/>
                        
                        <Button x:Name="SelectFolderButton"
                                Click="SelectFolderButton_Click"
                                Style="{StaticResource SelectFolderButtonStyle}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8B7;" FontSize="16"/>
                                <TextBlock Text="选择保存目录" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        
                        <TextBlock x:Name="SavePathText"
                                   Text=""
                                   FontSize="12"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   MaxLines="2"
                                   TextTrimming="CharacterEllipsis"/>
                        
                        <Button x:Name="SaveButton"
                                Click="SaveButton_Click"
                                IsEnabled="False"
                                Style="{StaticResource SaveButtonStyle}"
                                HorizontalAlignment="Stretch"
                                ToolTipService.ToolTip="保存图片 (Ctrl+S)">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                <TextBlock Text="保存图片" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="OpenFolderButton"
                                Click="OpenFolderButton_Click"
                                Style="{StaticResource OpenFolderButtonStyle}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE8DA;" FontSize="16"/>
                                <TextBlock Text="打开保存目录" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        
                        <TextBlock FontSize="12"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0"
                                   LineHeight="18">
                            <Run Text="数据来源：nekos.best API"/>
                            <LineBreak/>
                            <Run Text="图片仅供个人欣赏使用"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 提示卡片容器 - 支持多卡片并发显示 -->
                <StackPanel x:Name="ToastContainer"
                            Orientation="Vertical"
                            Spacing="8"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
